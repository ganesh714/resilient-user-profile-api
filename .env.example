# Application Server
PORT=8080
NODE_ENV=development

# Database Configuration
DB_HOST=database
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=secretpassword
DB_NAME=user_management

# External Enrichment Service Configuration
ENRICHMENT_SERVICE_URL=http://enrichment-service:8081/enrich
ENRICHMENT_TIMEOUT_MS=2000

# Circuit Breaker Configuration
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT_MS=30000
CB_HALF_OPEN_SUCCESS_THRESHOLD=3

# Retry Configuration
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=200

# Mock Service Behavior (For testing resilience)
MOCK_FAILURE_RATE=0.0
MOCK_LATENCY_MS=50
